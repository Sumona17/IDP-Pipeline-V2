# Vite exposes only variables prefixed with VITE_ to the browser bundle.
# These are build-time values for static hosting (S3/CloudFront); do not put secrets here.

VITE_APP_COGNITO_AUTHORITY=https://your-cognito-domain.auth.us-east-1.amazoncognito.com
VITE_APP_COGNITO_CLIENT_ID=your_client_id
VITE_APP_COGNITO_DOMAIN=https://your-cognito-domain.auth.us-east-1.amazoncognito.com

